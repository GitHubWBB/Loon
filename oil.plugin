#!name=⛽油价终极稳定版
#!desc=国内+国际油价+趋势+汇率+倒计时
#!author=ChatGPT
#!date=2026-03-22
#!icon=https://raw.githubusercontent.com/Toperlock/Quantumult/main/icon/oil.png

[Argument]

cron = input,"0 */6 * * *",tag=定时任务
city = input,"北京",tag=城市
intl = switch,true,tag=国际油价
notify = switch,true,tag=通知
key = input,"",tag=天行API Key

[Script]
cron {cron} script-path=https://raw.githubusercontent.com/GitHubWBB/Loon/main/js/oil.js, timeout=15, tag=⛽油价, img-url=https://raw.githubusercontent.com/Toperlock/Quantumult/main/icon/oil.png, argument=city={city}&intl={intl}&notify={notify}&key={key}
